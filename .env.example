# Dependency & License Inspector MCP — example environment (no secrets).
# Copy to .env and adjust; never commit .env with real secrets.

# Run in demo mode: no real OSV API calls, stub vulnerability and replacement data.
# DEMO.md and tests use this so the scenario works without network or API keys.
DEMO_MODE=false

# OSV API base URL (public, no key required).
OSV_API_BASE=https://api.osv.dev

# Cache TTL for scan results (seconds).
CACHE_TTL_SECONDS=300

# Comma-separated dirs to exclude from project scan (defaults in config if unset).
# EXCLUDE_DIRS=node_modules,.venv,__pycache__,target,.git

# Log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Optional: API key for extra data sources (e.g. Libraries.io). Leave empty for base/demo flow.
# LIBRARIES_IO_API_KEY=

# --- MCP access limits (security) ---
# If set, project_path in tools must be under this directory.
# ALLOWED_BASE_PATH=
# Max length of project_path / policy path (chars). Default 4096.
# MAX_INPUT_PATH_LENGTH=4096
# Max number of exclude_dirs entries. Default 100.
# MAX_EXCLUDE_DIRS=100
# Max policy payload size (bytes). Default 512KiB.
# MAX_POLICY_PAYLOAD_BYTES=524288
# Per-tool execution timeout (seconds). 0 = disabled. Default 120.
# TOOL_TIMEOUT_SECONDS=120
